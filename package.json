{
  "name": "imgconvert",
  "private": true,
  "version": "0.1.1",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "pnpm typecheck && pnpm lint",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deadcode": "knip --include files,dependencies --no-config-hints",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:image-quality": "node scripts/check-image-quality.mjs",
    "fuzz:prepare": "node scripts/prepare-fuzz-corpus.mjs",
    "fuzz:prepare:require-real": "node scripts/prepare-fuzz-corpus.mjs --require-real",
    "fuzz:check": "cargo +1.96.0 check --manifest-path fuzz/Cargo.toml --bins",
    "fuzz:replay": "node scripts/replay-fuzz-corpus.mjs",
    "fuzz:minimize": "node scripts/minimize-fuzz-artifacts.mjs --dry-run",
    "fuzz:minimize:run": "node scripts/minimize-fuzz-artifacts.mjs --run",
    "fuzz:smoke": "pnpm run fuzz:prepare && pnpm run fuzz:check && pnpm run fuzz:replay -- --skip-prepare",
    "fuzz:ci": "pnpm run fuzz:smoke",
    "e2e": "playwright test",
    "license:check": "pnpm run license:npm && pnpm run license:rust && pnpm run license:verify",
    "license:npm": "node scripts/check-npm-licenses.mjs",
    "license:rust": "cd src-tauri && cargo deny check licenses",
    "license:third-party": "node scripts/generate-third-party-licenses.mjs",
    "license:verify": "node scripts/generate-third-party-licenses.mjs --check",
    "audit:npm": "pnpm audit --prod",
    "audit:rust": "node scripts/audit-rust-advisories.mjs",
    "architecture:check": "node scripts/check-architecture-guardrails.mjs",
    "release:readiness": "node scripts/report-release-readiness.mjs",
    "release:readiness:github": "node scripts/report-release-readiness.mjs --scope=github",
    "release:readiness:github:ready": "node scripts/report-release-readiness.mjs --scope=github --require-publishable",
    "release:readiness:all": "node scripts/report-release-readiness.mjs --scope=all",
    "docs:check": "node scripts/check-readme-status.mjs",
    "release:readiness:check": "pnpm run docs:check && node scripts/report-release-readiness.mjs --check",
    "ci:cost:check": "node scripts/check-ci-cost-guardrails.mjs",
    "toolchain:check": "node scripts/check-native-toolchain.mjs",
    "toolchain:check:linux:deb": "node scripts/check-native-toolchain.mjs --linux-bundles=deb",
    "toolchain:check:linux:all": "node scripts/check-native-toolchain.mjs --linux-bundles=deb,rpm,appimage",
    "release:linux": "pnpm run toolchain:check:linux:all && node scripts/clean-linux-bundles.mjs --profile=release --bundles=deb,rpm,appimage && APPIMAGE_EXTRACT_AND_RUN=1 pnpm tauri build --ci --bundles deb,rpm,appimage && node scripts/scrub-linux-appimage.mjs --profile=release && node scripts/check-linux-bundle-artifacts.mjs --profile=release --bundles=deb,rpm,appimage && node scripts/generate-linux-release-checksums.mjs --profile=release --bundles=deb,rpm,appimage",
    "release:linux:debug": "pnpm run toolchain:check:linux:deb && node scripts/clean-linux-bundles.mjs --profile=debug --bundles=deb && pnpm tauri build --ci --debug --bundles deb && node scripts/check-linux-bundle-artifacts.mjs --profile=debug --bundles=deb",
    "release:linux:debug:all": "pnpm run toolchain:check:linux:all && node scripts/clean-linux-bundles.mjs --profile=debug --bundles=deb,rpm,appimage && APPIMAGE_EXTRACT_AND_RUN=1 pnpm tauri build --ci --debug --bundles deb,rpm,appimage && node scripts/scrub-linux-appimage.mjs --profile=debug && node scripts/check-linux-bundle-artifacts.mjs --profile=debug --bundles=deb,rpm,appimage",
    "release:linux:verify": "node scripts/check-linux-bundle-artifacts.mjs --bundles=deb,rpm,appimage",
    "release:linux:smoke:deb": "node scripts/smoke-linux-package-install.mjs --bundle=deb",
    "release:linux:smoke:deb:debug": "node scripts/smoke-linux-package-install.mjs --profile=debug --bundle=deb --convert-smoke",
    "release:linux:smoke:deb:docker": "node scripts/smoke-linux-package-install.mjs --bundle=deb --image=ubuntu:24.04 --convert-smoke",
    "release:linux:smoke:deb:debian": "node scripts/smoke-linux-package-install.mjs --bundle=deb --image=debian:13 --convert-smoke",
    "release:linux:smoke:rpm:docker": "node scripts/smoke-linux-package-install.mjs --bundle=rpm --image=fedora:latest --convert-smoke",
    "release:linux:smoke:appimage:docker": "node scripts/smoke-linux-package-install.mjs --bundle=appimage --image=ubuntu:24.04 --convert-smoke",
    "release:linux:smoke:docker": "node scripts/smoke-linux-package-matrix.mjs",
    "release:linux:checksums": "node scripts/generate-linux-release-checksums.mjs --bundles=deb,rpm,appimage",
    "release:updater:prepare": "node scripts/prepare-tauri-updater-release.mjs",
    "release:updater:sign": "node scripts/sign-tauri-updater-artifacts.mjs",
    "release:updater:manifest": "node scripts/generate-tauri-updater-manifest.mjs",
    "release:updater:verify": "node scripts/check-tauri-updater-manifest.mjs",
    "release:updater:smoke": "node scripts/smoke-tauri-updater-release.mjs",
    "release:updater:upgrade-smoke": "node scripts/smoke-tauri-in-app-updater.mjs --require-gui",
    "release:updater:upgrade-smoke:eligibility": "node scripts/smoke-tauri-in-app-updater.mjs --eligibility-only",
    "release:linux:updater": "node scripts/release-linux-updater.mjs",
    "release:updater:local": "pnpm run release:linux:updater && pnpm run release:updater:manifest && pnpm run release:updater:verify",
    "release:flatpak:prepare": "node scripts/prepare-flatpak-release.mjs",
    "release:flatpak:verify": "node scripts/check-flatpak-manifest.mjs && node scripts/check-flatpak-heic-extension.mjs && node scripts/check-flathub-metadata.mjs",
    "release:flathub:metadata": "node scripts/check-flathub-metadata.mjs",
    "release:flathub:metadata:lint": "node scripts/check-flathub-metadata.mjs --flathub-lint",
    "release:flathub:pr": "node scripts/prepare-flathub-pr.mjs --kind=all",
    "release:flathub:main-pr": "node scripts/prepare-flathub-pr.mjs --kind=main",
    "release:flathub:heic-pr": "node scripts/prepare-flathub-pr.mjs --kind=heic",
    "release:flatpak:heic:verify": "node scripts/check-flatpak-heic-extension.mjs",
    "release:flatpak:heic:smoke": "node scripts/smoke-flatpak-heic-extension.mjs",
    "release:flatpak:heic:real-smoke": "node scripts/smoke-flatpak-heic-runtime.mjs",
    "release:flatpak:heic:download-check": "node scripts/smoke-flatpak-heic-extension.mjs --download-only",
    "release:flatpak:smoke": "node scripts/smoke-flatpak-runtime.mjs --prepare --skip-fetch",
    "release:platform:check": "pnpm run architecture:check && pnpm run release:readiness:check && node scripts/check-platform-release-guardrails.mjs --platform=all --channel=all",
    "release:macos:check": "node scripts/check-platform-release-guardrails.mjs --platform=macos --channel=direct,store",
    "release:macos:direct:check": "node scripts/check-platform-release-guardrails.mjs --platform=macos --channel=direct",
    "release:macos:store:check": "node scripts/check-platform-release-guardrails.mjs --platform=macos --channel=store --require-store-env",
    "bench:platform": "node scripts/benchmark-platform.mjs",
    "bench:avif:macos": "node scripts/benchmark-macos-avif.mjs",
    "release:macos:smoke": "node scripts/smoke-macos-runtime.mjs",
    "release:macos": "pnpm run toolchain:check && node scripts/clean-macos-bundles.mjs --profile=release --bundles=dmg && pnpm tauri build --ci --bundles dmg && node scripts/check-macos-bundle-artifacts.mjs --profile=release --bundles=dmg",
    "release:macos:verify": "node scripts/check-macos-bundle-artifacts.mjs --profile=release --bundles=dmg",
    "release:macos:notarize": "node scripts/notarize-macos-dmg.mjs --profile=release",
    "release:macos:mas:prepare": "node scripts/prepare-macos-mas-release.mjs",
    "release:macos:mas": "pnpm run toolchain:check && IMGCONVERT_DISABLE_EXTERNAL_CODECS=1 pnpm run release:macos:mas:prepare && node scripts/clean-macos-bundles.mjs --profile=release --bundles=app && IMGCONVERT_DISABLE_EXTERNAL_CODECS=1 pnpm tauri build --ci --bundles app --config src-tauri/target/macos-mas/tauri.macos.mas.generated.conf.json && node scripts/check-macos-bundle-artifacts.mjs --profile=release --bundles=app --require-signed",
    "release:macos:mas:pkg": "node scripts/package-macos-mas-pkg.mjs",
    "release:windows:check": "node scripts/check-platform-release-guardrails.mjs --platform=windows --channel=direct,store",
    "release:windows:direct:check": "node scripts/check-platform-release-guardrails.mjs --platform=windows --channel=direct",
    "release:windows:store:check": "node scripts/check-platform-release-guardrails.mjs --platform=windows --channel=store --require-store-env",
    "release:windows:smoke": "node scripts/smoke-windows-runtime.mjs",
    "release:windows": "node scripts/clean-windows-bundles.mjs --profile=release --bundles=msi,nsis && pnpm tauri build --ci --bundles msi,nsis && node scripts/check-windows-bundle-artifacts.mjs --profile=release --bundles=msi,nsis",
    "release:windows:verify": "node scripts/check-windows-bundle-artifacts.mjs --profile=release --bundles=msi,nsis",
    "release:windows:sign": "node scripts/sign-windows-installers.mjs --profile=release --bundles=msi,nsis",
    "release:windows:install-smoke": "node scripts/smoke-windows-installers.mjs --profile=release --bundles=msi,nsis",
    "release:windows:signed": "pnpm run release:windows && pnpm run release:windows:sign",
    "release:windows:msix:prepare": "node scripts/prepare-windows-msix-release.mjs",
    "release:store-env:check": "node scripts/check-platform-release-guardrails.mjs --platform=all --channel=store --require-store-env",
    "quality:frontend": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm deadcode && pnpm test && pnpm build",
    "quality:rust": "pnpm run toolchain:check && cargo fmt --check && cargo clippy -p imgconvert-core -- -D warnings && cargo test -p imgconvert-core && cargo +1.96.0 fmt --manifest-path src-tauri/Cargo.toml --check && cargo +1.96.0 clippy --manifest-path src-tauri/Cargo.toml -- -D warnings && cargo +1.96.0 test --manifest-path src-tauri/Cargo.toml",
    "quality:security": "pnpm run docs:check && pnpm run architecture:check && pnpm run ci:cost:check && pnpm run license:check && cd src-tauri && cargo deny check bans sources",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "phosphor-svelte": "^3.1.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.22.0",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/svelte": "^5.4.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "eslint": "^9.39.4",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
