{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ImgConvert",
  "version": "0.1.1",
  "identifier": "com.ivmm.imgconvert",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "ImgConvert · 图片批量转换",
        "width": 900,
        "height": 680,
        "minWidth": 720,
        "minHeight": 540,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "ImgConvert contributors",
    "homepage": "https://github.com/yeagoo/imgconvert",
    "license": "Apache-2.0",
    "licenseFile": "../LICENSE",
    "category": "Photography",
    "shortDescription": "跨平台图片批量转换工具",
    "longDescription": "ImgConvert 是 Linux 优先的跨平台图片批量转换工具,使用 Rust 进程内图像管线转换 JPEG、PNG、WebP 与 AVIF。",
    "linux": {
      "deb": {
        "section": "graphics",
        "priority": "optional"
      },
      "rpm": {
        "release": "1"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
