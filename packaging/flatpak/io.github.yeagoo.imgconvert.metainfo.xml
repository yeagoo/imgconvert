<component type="desktop-application">
  <id>io.github.yeagoo.imgconvert</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>Apache-2.0</project_license>
  <name>ImgConvert</name>
  <summary>Batch image conversion tool</summary>
  <developer id="io.github.yeagoo">
    <name>ImgConvert contributors</name>
  </developer>
  <description>
    <p>ImgConvert converts batches of JPEG, PNG, WebP, and AVIF images with a Rust in-process image pipeline.</p>
    <p>The Flatpak main package disables optional external codec helpers by default. HEIC/HEIF helper plugins are intentionally not bundled.</p>
  </description>
  <launchable type="desktop-id">io.github.yeagoo.imgconvert.desktop</launchable>
  <categories>
    <category>Graphics</category>
    <category>Photography</category>
  </categories>
  <url type="homepage">https://github.com/yeagoo/imgconvert</url>
  <url type="vcs-browser">https://github.com/yeagoo/imgconvert</url>
  <url type="bugtracker">https://github.com/yeagoo/imgconvert/issues</url>
  <content_rating type="oars-1.1" />
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/yeagoo/imgconvert/v0.1.1/packaging/flatpak/screenshots/main.png</image>
      <caption>Batch image conversion queue and output settings</caption>
    </screenshot>
  </screenshots>
  <releases>
    <release version="0.1.1" date="2026-07-06">
      <description>
        <p>Initial Linux release candidate with JPEG, PNG, WebP, AVIF, and optional external HEIC import boundaries.</p>
      </description>
    </release>
  </releases>
</component>
