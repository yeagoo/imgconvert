{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/main.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "scripts/*.mjs",
    "tests/**/*.test.ts",
    "e2e/**/*.spec.ts"
  ],
  "project": [
    "src/**/*.{ts,svelte}",
    "tests/**/*.ts",
    "e2e/**/*.ts",
    "*.config.ts",
    "scripts/*.mjs"
  ],
  "ignore": ["src/lib/components/ui/**", "src/vite-env.d.ts"],
  "ignoreDependencies": [
    "@internationalized/date",
    "@testing-library/svelte",
    "@tauri-apps/plugin-opener",
    "@tauri-apps/cli",
    "tw-animate-css"
  ]
}
